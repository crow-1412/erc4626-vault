# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# WalletConnect project ID — get a free one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=dfef74a6705259bbc69b6cc2bc0ba159

# Sepolia RPC URL — same as your forge .env (can be the same Alchemy/Infura key)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Contract addresses — filled in after running the deploy script
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Deployer private key (with 0x prefix)
PRIVATE_KEY=0x

# Sepolia RPC URL — get a free one from Alchemy or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan API key — needed for --verify flag
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Optional: override fee recipient address (defaults to deployer)
# FEE_RECIPIENT=0x...

# Optional: override fees (defaults: 100 = 1% deposit, 50 = 0.5% withdraw)
# DEPOSIT_FEE_BPS=100
# WITHDRAW_FEE_BPS=50
